# VeriVerse BSC — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env

# ==========================================================
# REQUIRED — Signing Keys
# ==========================================================

# Deployer / client signing key (used for deploying contracts + sending txs)
CLIENT_PRIVATE_KEY=0x...

# Demo run signing key (can be the same as CLIENT_PRIVATE_KEY)
PRIVATE_KEY=0x...

# ==========================================================
# Network
# ==========================================================

# Target network: bsc_testnet (default) | bsc
TARGET_NETWORK=bsc_testnet

# BNB Chain Testnet RPC (public node, no key needed)
BSC_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# ==========================================================
# Contract Addresses
# Already deployed on BSC Testnet — use these directly
# ==========================================================

VT_REGISTRY_ADDRESS=0x1545655b6d42A51E5e8c85Ed162bD84aba35480C
SEMAPHORE_ADDRESS=0xF974dcD3E2D744933aF81C1b94501E311114ac6B
USDT_ADDRESS=0xF8De09e7772366A104c4d42269891AD1ca7Be720

# VeriEscrow — fill in after running: npx hardhat run scripts/deploy_escrow.js
ESCROW_ADDRESS=

# First block to scan for PCEG events (0 = scan all, slow; set to deploy block for speed)
VT_REGISTRY_DEPLOY_BLOCK=0

# ==========================================================
# Dashboard Server (optional — all have defaults)
# ==========================================================

PORT=3001
PCEG_API_URL=http://127.0.0.1:8002
TOKEN_MODE=mock               # mock | real

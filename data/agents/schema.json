{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VeriVerse Agent Description (MVP)",
  "type": "object",
  "required": [
    "agentId",
    "name",
    "description",
    "claims",
    "supportedTasks",
    "owner",
    "updatedAt"
  ],
  "properties": {
    "agentId": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedTasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "defi_tvl"
        ]
      }
    },
    "owner": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
